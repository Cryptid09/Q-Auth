# Environment variables for local development
# Copy to .env and adjust values as needed

# --- PostgreSQL ---
POSTGRES_DB=oppex_auth
POSTGRES_USER=oppex
POSTGRES_PASSWORD=oppex_secret
POSTGRES_PORT=5433

# --- Quarkus ---
QUARKUS_PORT=8080

# --- Gateway ---
GATEWAY_PORT=3001
QUARKUS_BASE_URL=http://localhost:8080
SESSION_SECRET=change-this-to-a-long-random-string-in-production
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# --- Frontend ---
VITE_API_URL=/api
VITE_GOOGLE_CLIENT_ID=

# --- SMTP (Gmail) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=REQUIRED
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
